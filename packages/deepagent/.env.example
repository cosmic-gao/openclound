# deepagent 配置示例。复制为 .env 后按需修改:
#   cp .env.example .env
# 说明:.env 已被 .gitignore 忽略;此文件(.env.example)可提交。
# 优先级:shell 环境变量 / CLI 参数 > .env > 代码默认值。

# —— 模型 / 网关 ——
# litellm 网关 /v1 地址(默认指向 openclound 网关)
DEEPAGENT_BASE_URL=https://aigateway-sandbox.mspbots.ai/v1
# 网关密钥(必填;也兼容 OPENAI_API_KEY)
DEEPAGENT_API_KEY=
# 模型名(由网关路由到实际后端)
DEEPAGENT_MODEL=claude-sonnet-4-6
# 采样温度
DEEPAGENT_TEMPERATURE=0.0
# 主模型失败时的备用模型(留空则不启用回退)
# DEEPAGENT_FALLBACK_MODEL=

# —— 工作区 ——
# agent 的文件系统根目录
DEEPAGENT_WORKSPACE=.deepagent

# —— 能力开关(1/true/yes/on 为真) ——
DEEPAGENT_ENABLE_SHELL=1
DEEPAGENT_ENABLE_FILE_SEARCH=0
DEEPAGENT_ENABLE_HITL=0

# —— 安全:PII 脱敏策略 off/block/redact/mask/hash ——
DEEPAGENT_PII_STRATEGY=off

# —— 运行约束 / 上下文(留空使用默认) ——
# DEEPAGENT_MODEL_CALL_LIMIT=
# DEEPAGENT_TOOL_CALL_LIMIT=
DEEPAGENT_MODEL_MAX_RETRIES=2
DEEPAGENT_TOOL_MAX_RETRIES=2
DEEPAGENT_CONTEXT_EDIT_TRIGGER_TOKENS=100000
# DEEPAGENT_SUMMARIZE_TRIGGER_TOKENS=
DEEPAGENT_SUMMARIZE_KEEP_MESSAGES=20
