# omniagent 配置示例。复制为 .env 后按需修改:
#   cp .env.example .env
# 说明:.env 已被 .gitignore 忽略;此文件(.env.example)可提交。
# 优先级:shell 环境变量 > .env > 代码默认值。
#
# 注意:这里只有 **进程级默认 / fallback**。每个 agent 的形态与开关
# (mode / model / prompt / tools / permission / review / mcp)是 per-assistant 配置,
# 放在 assistant 的 config.configurable(opencode / Claude 风格),不在本文件。

# —— 模型连接(OpenAI 标准变量) ——
# OpenAI 兼容 /v1 端点;留空则用内置默认网关。可指向 litellm 网关、MiniMax 等
OPENAI_BASE_URL=https://aigateway-sandbox.mspbots.ai/v1
# 密钥(必填)
OPENAI_API_KEY=

# —— 模型默认(可被 assistant 的 config.model / temperature 覆盖) ——
AGENT_MODEL=claude-sonnet-4-6
AGENT_TEMPERATURE=0.0
# 主模型失败时的备用模型(留空则不启用回退)
# AGENT_FALLBACK_MODEL=

# —— 工作区 / skills(部署级根目录) ——
# agent 文件系统根:运行时按 work/<tenant>/<user>/<agent> 隔离
AGENT_WORKSPACE=.agent
# skill 根:<skills_root>/<tenant>/<agent>(每个 agent 独立一套)
AGENT_SKILLS_ROOT=.agent/skills

# —— 能力 / 安全默认 ——
# ripgrep 文件搜索(deepagents 已有 glob/grep,默认关)
AGENT_ENABLE_FILE_SEARCH=0
# PII 脱敏策略 off/block/redact/mask/hash
AGENT_PII_STRATEGY=off

# —— 运行约束 / 上下文(留空使用默认) ——
# 单次运行模型迭代上限是 per-agent 的 config.steps;此处仅工具调用上限默认
# AGENT_TOOL_CALL_LIMIT=
AGENT_MODEL_MAX_RETRIES=2
AGENT_TOOL_MAX_RETRIES=2
AGENT_CONTEXT_EDIT_TRIGGER_TOKENS=100000

# ===================== Aegra 部署(self-hosted LangGraph Platform) =====================
# 仅在用 `aegra dev` / `aegra serve` 部署时需要。Aegra 用 Postgres 接管持久化
# (checkpointer / 线程 / 运行),agent 的图以 platform_managed 暴露。

# 指向本仓库的 aegra.json
AEGRA_CONFIG=aegra.json

# —— Postgres(`aegra dev` 会用 Docker 起一个;`aegra serve` 用你自己的库) ——
POSTGRES_DB=omniagent
POSTGRES_USER=omniagent
POSTGRES_PASSWORD=omniagent_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# 或直接给完整连接串(优先级更高;可指向已有/托管库 RDS/Cloud SQL/Supabase/Neon):
# DATABASE_URL=postgresql://omniagent:omniagent_secret@localhost:5432/omniagent
# PGSSLMODE=require                  # 托管库要 TLS 时(放 env,别塞进 URL)
# 生产:不在启动时自动建表,改由 CI 跑 `aegra db upgrade`
# RUN_MIGRATIONS_ON_STARTUP=false

# —— 服务 ——
HOST=0.0.0.0
PORT=2026
# 鉴权:配了 aegra.json 的 auth.path(omniagent.auth)即启用自定义鉴权。
# Aegra 仅内网部署,身份头由业务方网关在内网注入(X-User-Id / X-Tenant-Id),
# 网络隔离即信任边界,无需 ServiceKey;缺头则回退匿名 + public。
AUTH_TYPE=custom
LOG_LEVEL=INFO
