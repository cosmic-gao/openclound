# cp .env.example .env —— 进程级配置 + 模型连接默认(assistant config 未配时回退到此)。
AGENT_WORKSPACE=.agent

# 模型连接默认(assistant config 未提供对应项时用这里;留空则必须由 config 提供)
AGENT_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=

POSTGRES_HOST=postgres
POSTGRES_PORT=15432
POSTGRES_DB=omniagent
POSTGRES_USER=omniagent
POSTGRES_PASSWORD=change-me

REDIS_BROKER_ENABLED=true
REDIS_URL=redis://redis:16379/0

AUTH_TYPE=custom
HOST=0.0.0.0
PORT=2026
