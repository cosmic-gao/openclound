# 复制为 .env。模型连接与 agent 行为都是 per-assistant(放 assistant config),不在此配。
# 本文件仅进程级运行参数 + Aegra 部署。详见 README。

# 工作区根:backend root = <AGENT_WORKSPACE>/<agent>
AGENT_WORKSPACE=.agent

# Aegra 部署(Postgres;`aegra serve` 启动自动迁移)
POSTGRES_DB=omniagent
POSTGRES_USER=omniagent
POSTGRES_PASSWORD=omniagent_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

HOST=0.0.0.0
PORT=2026

# 走自定义鉴权(omniagent auth.py);默认 noop=匿名,会破坏 per-user 会话隔离
AUTH_TYPE=custom

# 多实例横向扩展(可选):REDIS_BROKER_ENABLED=true  REDIS_URL=redis://localhost:6379/0
