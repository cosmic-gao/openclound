{
  "name": "openclound",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.22.3",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev": "pnpm -r --parallel --if-present run dev",
    "test": "pnpm -r --if-present run test",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@openclound/tsconfig": "workspace:*",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
