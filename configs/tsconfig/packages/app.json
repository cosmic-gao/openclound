{
  "display": "@openclound/tsconfig — app(应用,增量片段)",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "rootDir": "${configDir}/src",
    "outDir": "${configDir}/dist",
    "tsBuildInfoFile": "${configDir}/dist/.tsbuildinfo"
  },
  "include": ["${configDir}/src/**/*"],
  "exclude": ["${configDir}/src/**/*.test.ts", "${configDir}/src/**/*.spec.ts"]
}
