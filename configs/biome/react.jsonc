{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  // 在 base 基线之上启用 React lint domain(检测到 react>=16 时自动激活相关规则)
  "extends": ["./base.jsonc"],
  "linter": {
    "domains": {
      "react": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double"
    }
  }
}
