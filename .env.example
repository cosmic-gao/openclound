AGENT_WORKSPACE=.agent

OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=

AEGRA_CONFIG=aegra.json
AUTH_TYPE=custom
# 多 pod K8s 设 false,改用带外 aegra db upgrade
RUN_MIGRATIONS_ON_STARTUP=true

# POSTGRES_HOST 必须是 compose 服务名 postgres;端口随改,postgres 容器会监听该端口
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# REDIS_URL 的 host 必须是服务名 redis,端口要与 REDIS_PORT 一致
REDIS_BROKER_ENABLED=true
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

HOST=0.0.0.0
PORT=2026

# WORKER_COUNT=3
# N_JOBS_PER_WORKER=10
