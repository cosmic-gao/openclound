# cp .env.example .env —— 进程级配置 + 模型连接默认(assistant config 未配时回退到此)。
AGENT_WORKSPACE=.agent

# 模型连接默认(assistant config 未提供对应项时用这里;留空则必须由 config 提供)
AGENT_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=

# 外部托管 Postgres(Aegra 持久化:checkpointer/线程/运行/store;本地与生产一致)
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# 外部托管 Redis(多实例 worker 队列;单实例可设 REDIS_BROKER_ENABLED=false)
REDIS_BROKER_ENABLED=true
REDIS_URL=redis://:change-me@your-redis-host:6379/0

AUTH_TYPE=custom
HOST=0.0.0.0
PORT=2026
