# cp .env.example .env。Aegra 进程级配置 + agentos 模型连接默认;本地(Windows)与生产共用。
AGENT_WORKSPACE=.agent

# 模型连接默认(assistant config 未提供对应项时回退;留空则必须由 config 提供)
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=

# 托管 Postgres(Aegra 持久化)。托管库通常强制 SSL,故用 DATABASE_URL 带 sslmode,
# Aegra 会自动把 sslmode 翻译为 asyncpg 的 ssl。密码含特殊字符须 URL 编码(@ -> %40)。
DATABASE_URL=postgresql://user:change-me@your-postgres-host:5432/agentos?sslmode=require

# 托管 Redis(多实例 worker 队列 + SSE)。TLS 用 rediss://;带密码 redis://:pwd@host:port/0
REDIS_BROKER_ENABLED=true
REDIS_URL=rediss://:change-me@your-redis-host:6379/0

AUTH_TYPE=custom
HOST=0.0.0.0
PORT=2026
